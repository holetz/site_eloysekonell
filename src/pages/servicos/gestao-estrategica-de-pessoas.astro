---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FaqBlock from '../../components/FaqBlock.astro';

const SITE_URL = 'https://eloysekonell.com.br';

const title = 'Gestão Estratégica de Pessoas para PMEs | Eloyse Konell';
const description =
  'Como estruturar gestão de pessoas em PMEs sem RH dedicado: framework aplicado, ciclos curtos, decisões consistentes.';
const canonical = `${SITE_URL}/servicos/gestao-estrategica-de-pessoas/`;

const breadcrumb = [
  { label: 'Início', href: '/' },
  { label: 'Serviços', href: '/servicos/' },
  { label: 'Gestão Estratégica de Pessoas' },
];

const frentesPriorizadas = [
  {
    ordem: '01',
    titulo: 'Cultura e valores operacionalizados',
    texto:
      'Não como placa na parede. Como conjunto de critérios que guia contratação, promoção e desligamento. Sem isso, cada decisão de pessoas depende do humor do sócio no dia.',
  },
  {
    ordem: '02',
    titulo: 'Atração e onboarding estruturado',
    texto:
      'Uma empresa que não sabe explicar por que alguém deveria trabalhar nela vai contratar por acidente — e perder por falta de acolhimento. Estruturar o processo de chegada reduz rotatividade nos primeiros 90 dias.',
  },
  {
    ordem: '03',
    titulo: 'Ciclo de feedback e conversas de desempenho',
    texto:
      'A maioria das PMEs só avalia desempenho quando precisa demitir ou promover. Ciclos regulares de feedback transformam o que era surpresa em conversa esperada — e criam responsabilidade compartilhada por resultado.',
  },
  {
    ordem: '04',
    titulo: 'Trilhas de desenvolvimento e crescimento',
    texto:
      'Pessoas ficam onde enxergam futuro. Uma trilha de desenvolvimento não precisa ser um plano de carreira corporativo com 20 níveis. Precisa ser uma resposta honesta à pergunta: "o que precisa acontecer para eu crescer aqui?"',
  },
  {
    ordem: '05',
    titulo: 'Planejamento de sucessão',
    texto:
      'Toda empresa chega num ponto em que o sócio não pode — e não deveria — carregar sozinho. Mapear quem sustenta o negócio se alguém sair é uma decisão estratégica, não um exercício de RH.',
  },
  {
    ordem: '06',
    titulo: 'Remuneração estratégica',
    texto:
      'Salário é custo. Remuneração estratégica é investimento com retorno esperado. Estruturar faixas, benefícios e variável com critério reduz injustiças percebidas e dá à empresa alavancas concretas de retenção.',
  },
];

const faqs = [
  {
    q: 'Empresa com 20 pessoas precisa de gestão estratégica?',
    a: 'Sim — e na maioria dos casos, essa é exatamente a hora certa. Empresas com 15 a 50 pessoas estão num ponto crítico: já saíram do modo startup onde o sócio conhece todo mundo, mas ainda não têm estrutura para sustentar o crescimento. É aqui que o caos começa se as bases de gestão de pessoas não forem construídas. Esperar ter 100 funcionários para estruturar costuma sair muito mais caro.',
  },
  {
    q: 'É o mesmo que ter um RH terceirizado?',
    a: 'Não. RH terceirizado geralmente opera o dia a dia: folha, admissões, demissões, obrigações legais. Gestão estratégica de pessoas é diferente — é definir prioridades, construir processos de desenvolvimento, estruturar critérios de decisão sobre talento. As duas coisas podem coexistir, mas atendem a perguntas distintas. Uma cuida do operacional; a outra cuida da direção.',
  },
  {
    q: 'Como você ajuda se eu não tenho ninguém de RH?',
    a: 'Esse é exatamente o perfil mais comum das empresas com quem trabalho. O processo começa com um diagnóstico da situação atual — o que existe, o que está funcionando, o que está gerando custo invisível. A partir daí, definimos juntos quais frentes atacar primeiro, construímos os processos e treinamos quem vai operá-los (muitas vezes o próprio gestor ou o sócio). O objetivo é que, ao final, a empresa consiga rodar sem depender da minha presença contínua.',
  },
  {
    q: 'Funciona para empresa familiar?',
    a: 'Funciona — e em empresas familiares, é ainda mais urgente. A mistura de papéis (sócio, familiar, gestor) cria ambiguidades que se acumulam em conflitos de gestão de pessoas. Estruturar critérios claros de contratação, promoção, remuneração e desenvolvimento é o que separa uma empresa familiar que cresce de uma que implode nas próximas gerações. Tenho certificação em Governança Corporativa em Empresas Familiares (IBGC) e trabalho com essa realidade com frequência.',
  },
  {
    q: 'O sócio precisa estar envolvido?',
    a: 'Sim, no diagnóstico e na definição de prioridades. A gestão de pessoas de uma PME reflete os valores, as decisões e os limites dos sócios — trabalhar sem esse alinhamento produz documentos bonitos que ninguém aplica. Dito isso, o objetivo do processo é justamente criar estruturas que reduzam a dependência do sócio nas decisões cotidianas de pessoas. O envolvimento inicial é alto; depois, vai diminuindo à medida que os processos ganham autonomia.',
  },
];

const postsRelacionados = [
  {
    href: '/blog/rh-futuro/',
    titulo: 'O RH do Futuro Já Chegou — e Ele Não É o Que Você Esperava',
  },
  {
    href: '/blog/saude-mental-estrategia/',
    titulo: 'Saúde Mental no Trabalho: Por Que Isso É Estratégia, Não Benefício',
  },
  {
    href: '/blog/hora-de-mudar/',
    titulo: 'Como Saber se É Hora de Mudar de Emprego (ou de Liderança)',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE_URL}/servicos/gestao-estrategica-de-pessoas/#service`,
  name: 'Gestão Estratégica de Pessoas',
  serviceType: 'Gestão Estratégica de Pessoas',
  description:
    'Estruturação de gestão de pessoas para PMEs sem RH dedicado — diagnóstico, priorização, ciclos curtos de feedback e desenvolvimento, planejamento de sucessão.',
  url: canonical,
  inLanguage: 'pt-BR',
  provider: {
    '@id': `${SITE_URL}/#eloyse`,
  },
  isPartOf: {
    '@id': `${SITE_URL}/#business`,
  },
  areaServed: {
    '@type': 'State',
    name: 'Santa Catarina',
    addressCountry: 'BR',
  },
  audience: {
    '@type': 'Audience',
    audienceType: 'PMEs, empresas familiares, diretores e sócios sem área de RH estruturada',
  },
};
---

<PageLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumb={breadcrumb}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <PageHero
    slot="hero"
    eyebrow="Serviços"
    title="Gestão Estratégica de Pessoas"
    deck="Para PMEs que crescem e precisam estruturar gestão de pessoas sem montar um RH inteiro."
  />

  <!-- O QUE É GESTÃO ESTRATÉGICA DE PESSOAS -->
  <section class="page-section gep-intro">
    <div class="wrap">
      <h2>O que é gestão estratégica de pessoas?</h2>
      <p>
        Gestão estratégica de pessoas não é sobre folha de pagamento, ponto eletrônico ou homologação
        de rescisão. Esses são processos operacionais necessários, mas não são o que diferencia
        empresas que crescem das que travam.
      </p>
      <p>
        Gestão estratégica de pessoas é colocar pessoas no centro das decisões de negócio. É perguntar:
        quem preciso ter aqui para que a estratégia dos próximos três anos funcione? O que precisa
        mudar na minha liderança para que minha empresa pare de depender de mim em tudo? Como estruturo
        crescimento sem perder as pessoas que fazem a empresa funcionar?
      </p>
      <p>
        Essas não são perguntas de RH. São perguntas de negócio respondidas pela lente de pessoas.
        E é exatamente isso que uma consultoria estratégica de pessoas faz: traduzir a estratégia do
        negócio em decisões claras sobre quem contratar, como desenvolver, o que reconhecer e como
        construir liderança que sustente crescimento.
      </p>
      <p>
        Para uma PME, isso significa sair do modo reativo — apagando incêndios de pessoas — e entrar
        num modo intencional, onde as decisões sobre talento têm critério, consistência e conexão com
        onde o negócio quer chegar.
      </p>
      <p>
        A diferença prática entre uma empresa que tem gestão estratégica de pessoas e uma que não tem
        aparece nos momentos críticos: quando a empresa precisa crescer rápido e não sabe se tem a
        liderança certa para isso; quando um colaborador-chave pede demissão e paralisa uma área inteira;
        quando os sócios divergem sobre como recompensar e reter um profissional estratégico. Sem
        estrutura de pessoas, essas situações viram crise. Com estrutura, viram decisão.
      </p>
    </div>
  </section>

  <!-- POR QUE PMEs ADIAM -->
  <section class="page-section gep-adiamento">
    <div class="wrap">
      <h2>Por que PMEs adiam estruturar gestão de pessoas?</h2>
      <p>
        A resposta mais comum é: "ainda não temos tamanho para isso." Mas essa lógica tem um problema:
        quando a empresa chega ao tamanho que o sócio imagina ser o correto, os problemas de pessoas
        já acumularam camadas — e o custo de resolver é muito maior do que teria sido prevenir.
        Ironicamente, é exatamente o crescimento que torna o adiamento mais custoso: cada novo
        colaborador contratado sem processo de integração, cada promoção feita sem critério, cada
        conflito de equipe resolvido na base do improviso vai se multiplicando conforme a empresa escala.
      </p>
      <p>
        Os sintomas aparecem cedo. O líder de pessoas na empresa é o próprio sócio, que acumula dez
        outras funções. As contratações acontecem por urgência, não por critério. A avaliação de
        desempenho existe apenas na cabeça do gestor, não como processo estruturado. Quando alguém
        pede demissão, é sempre uma surpresa — nunca havia sinal visível de insatisfação porque não
        existia espaço regular para conversas honestas.
      </p>
      <p>
        O custo de adiar não é abstrato. Rotatividade custa entre 50% e 150% do salário anual de cada
        pessoa que sai. Um líder despreparado que gera conflito no time tem impacto direto na
        produtividade. Uma cultura que se forma sem intenção atrai pessoas erradas e afasta as certas.
        Esses são custos que nunca aparecem na DRE, mas sangram o negócio todos os meses.
      </p>
      <p>
        Outro motivo para o adiamento é a sensação de que estruturar gestão de pessoas significa
        criar uma burocracia corporativa que não combina com a agilidade da empresa. Esse medo é
        legítimo — mas desnecessário. Estrutura não é burocracia. É clareza. E clareza é o que
        permite que uma PME tome decisões rápidas e consistentes sem depender de um único sócio
        para resolver tudo. Uma empresa ágil com processos claros de pessoas toma decisões mais
        rápido do que uma empresa sem processos — porque não precisa reinventar o critério a cada
        nova situação.
      </p>
    </div>
  </section>

  <!-- COMO ESTRUTURAR SEM MONTAR UM RH INTEIRO -->
  <section class="page-section gep-framework">
    <div class="wrap">
      <h2>Como estruturar sem montar um RH inteiro?</h2>
      <p class="gep-intro-text">
        A boa notícia é que estruturar gestão de pessoas não exige criar uma área nova, contratar um
        diretor de RH ou implementar um sistema de gestão complexo. Exige método. E método se aprende
        e se aplica em ciclos curtos.
      </p>
      <ol class="framework-lista">
        <li class="framework-item">
          <span class="framework-num">01</span>
          <div class="framework-content">
            <h3>Diagnóstico</h3>
            <p>
              Antes de qualquer ação, é preciso entender o que está acontecendo de verdade — não o
              sintoma visível, mas a causa raiz. O diagnóstico mapeia o que existe, o que está
              funcionando, o que está gerando custo invisível e onde a empresa está mais vulnerável.
              Inclui entrevistas com sócios e líderes, análise de dados de turnover e absenteísmo, e
              avaliação do nível de maturidade dos processos existentes.
            </p>
          </div>
        </li>
        <li class="framework-item">
          <span class="framework-num">02</span>
          <div class="framework-content">
            <h3>Priorização (3 a 5 frentes)</h3>
            <p>
              Com o diagnóstico em mãos, o próximo passo é resistir à tentação de resolver tudo ao
              mesmo tempo. Priorizamos de 3 a 5 frentes com maior impacto para aquele negócio naquele
              momento — não o que é mais urgente, mas o que vai gerar mais retorno com o esforço
              disponível. Cada frente tem um dono, uma meta e um prazo.
            </p>
          </div>
        </li>
        <li class="framework-item">
          <span class="framework-num">03</span>
          <div class="framework-content">
            <h3>Ciclos curtos de 90 dias</h3>
            <p>
              Cada frente é executada em ciclos de 90 dias. Ciclos curtos funcionam porque criam
              urgência sem afogar a equipe, permitem ajuste de rota antes que os erros se acumulem,
              e geram resultados visíveis rápido o suficiente para manter o comprometimento da
              liderança. Noventa dias é tempo suficiente para implantar um processo novo e coletar
              os primeiros sinais de eficácia.
            </p>
          </div>
        </li>
        <li class="framework-item">
          <span class="framework-num">04</span>
          <div class="framework-content">
            <h3>Mensuração</h3>
            <p>
              Gestão de pessoas sem indicadores é opinião. Cada frente tem métricas definidas desde o
              início: turnover, tempo de preenchimento de vagas, NPS interno, taxa de conclusão de
              PDIs, índice de promoções internas. Não é burocracia — é o que permite ao sócio tomar
              decisões de pessoas com dados, não com intuição.
            </p>
          </div>
        </li>
        <li class="framework-item">
          <span class="framework-num">05</span>
          <div class="framework-content">
            <h3>Ajuste e próximo ciclo</h3>
            <p>
              Ao final de cada ciclo, revisamos o que funcionou, o que não funcionou e o que mudou
              no contexto do negócio. O plano é atualizado, as próximas frentes são priorizadas e
              o ciclo recomeça. Com o tempo, a empresa internalizou o método — e o processo roda
              sem depender da consultoria.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- QUAIS FRENTES PRIORIZAR PRIMEIRO -->
  <section class="page-section gep-frentes">
    <div class="wrap">
      <h2>Quais frentes priorizar primeiro?</h2>
      <p class="gep-intro-text">
        A resposta depende do diagnóstico — mas há uma ordem lógica que funciona para a maioria das
        PMEs brasileiras entre 15 e 100 funcionários. Cada frente abaixo representa uma camada de
        maturidade que sustenta a próxima. Priorizar a sequência correta evita o erro clássico de
        investir em treinamento sem ciclos de feedback que transformem aprendizado em mudança real
        de comportamento, ou de criar políticas de remuneração sem ter cultura e critérios de
        desempenho bem definidos.
      </p>
      <div class="frentes-grid">
        {frentesPriorizadas.map((f) => (
          <div class="frente-card">
            <span class="frente-ordem">{f.ordem}</span>
            <h3>{f.titulo}</h3>
            <p>{f.texto}</p>
          </div>
        ))}
      </div>
      <p class="gep-obs">
        Empresas familiares têm uma sétima frente crítica: <strong>separação entre gestão e família</strong>.
        Definir critérios claros para quem da família pode trabalhar na empresa, com qual papel e com
        qual remuneração, é o que impede que decisões de negócio sejam contaminadas por dinâmicas
        de parentesco. Essa frente raramente aparece na lista de prioridades — mas quando não é
        endereçada, acaba sendo a causa raiz de quase tudo que vai mal.
      </p>
    </div>
  </section>

  <!-- QUANTO TEMPO ATE VER MUDANÇA -->
  <section class="page-section gep-prazo">
    <div class="wrap gep-prazo-inner">
      <div class="gep-prazo-content">
        <h2>Quanto tempo até ver mudança real?</h2>
        <p>
          A resposta honesta é: depende do ponto de partida e da velocidade de execução. Mas há uma
          janela razoável para expectativas realistas.
        </p>
        <p>
          Nos primeiros 90 dias, é possível ver resultados iniciais: um processo de onboarding que
          funciona, conversas de desempenho acontecendo com regularidade, critérios de contratação
          mais claros. São mudanças de processo, visíveis internamente, mas ainda não sentidas como
          "transformação cultural".
        </p>
        <p>
          Entre 3 e 6 meses, os impactos começam a aparecer em indicadores: queda no turnover,
          redução no tempo de adaptação de novos contratados, melhora na clareza de papéis dentro
          dos times. É o ponto em que os sócios costumam dizer "antes eu resolvia isso sozinho; agora
          a liderança cuida".
        </p>
        <p>
          Com 12 meses de processo consistente, a empresa tem um sistema rodando — não perfeito, mas
          funcional. As decisões de pessoas têm critério. O sócio não é mais o único que sabe de tudo.
          E quando alguém sai, a empresa tem como repor com clareza, não com desespero.
        </p>
        <p>
          Vale dizer o que "ver mudança real" não significa: não é uma transformação cultural completa
          do dia para a noite, não é a resolução de todos os problemas de pessoas em um ano, e não é
          a independência total do sócio na gestão. Mudança real é a empresa tomar decisões de pessoas
          com mais consistência do que tomava antes — cada decisão embasada em critério, não em
          urgência ou intuição isolada. Esse é o padrão que define se o processo está funcionando.
        </p>
      </div>
      <div class="gep-prazo-destaque">
        <blockquote class="gep-quote">
          "O objetivo não é que a empresa dependa menos de mim. É que ela dependa menos de
          uma única pessoa — seja o sócio ou qualquer outro."
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="page-section gep-faq">
    <div class="wrap">
      <FaqBlock faqs={faqs} title="Perguntas frequentes sobre gestão estratégica de pessoas" />
    </div>
  </section>

  <!-- POSTS RELACIONADOS -->
  <section class="page-section gep-posts">
    <div class="wrap">
      <h2>Para aprofundar</h2>
      <p class="gep-intro-text">
        Artigos do blog com reflexões diretamente ligadas ao tema de gestão estratégica de pessoas:
      </p>
      <ul class="posts-lista">
        {postsRelacionados.map((p) => (
          <li>
            <a href={p.href}>{p.titulo} →</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="page-section gep-cta">
    <div class="wrap">
      <div class="gep-cta-inner">
        <p class="gep-cta-texto">
          Pronto para estruturar a gestão de pessoas da sua empresa?
        </p>
        <p class="gep-cta-sub">
          Vamos conversar sobre onde sua empresa está e o que precisa acontecer para chegar onde você quer.
        </p>
        <a href="/contato/" class="btn">Falar com a Eloyse</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .wrap {
    max-width: 860px;
  }

  /* Intro text reutilizado em múltiplas seções */
  .gep-intro-text {
    max-width: 720px;
    color: var(--taupe);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  /* Seções de texto corrido */
  .gep-intro p,
  .gep-adiamento p,
  .gep-prazo-content p {
    color: var(--taupe);
    line-height: 1.75;
    max-width: 720px;
    margin-bottom: 20px;
  }

  .gep-intro p:last-child,
  .gep-adiamento p:last-child,
  .gep-prazo-content p:last-child {
    margin-bottom: 0;
  }

  /* Framework steps */
  .framework-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .framework-item {
    display: flex;
    gap: 40px;
    padding: 36px 0;
    border-bottom: 1px solid var(--line);
  }

  .framework-item:first-child {
    border-top: 1px solid var(--line);
  }

  .framework-num {
    font-family: var(--serif);
    font-size: 2.8rem;
    font-weight: 300;
    color: var(--bronze);
    line-height: 1;
    flex-shrink: 0;
    width: 56px;
    padding-top: 4px;
  }

  .framework-content h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--olive-deep);
    margin: 0 0 12px;
  }

  .framework-content p {
    margin: 0;
    color: var(--taupe);
    line-height: 1.65;
    max-width: 640px;
  }

  /* Frentes grid */
  .frentes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .frente-card {
    background: var(--sand-warm);
    border: 1px solid var(--sand-deep);
    border-radius: 4px;
    padding: 32px 28px;
    position: relative;
  }

  .frente-ordem {
    font-family: var(--serif);
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--bronze);
    display: block;
    margin-bottom: 12px;
    line-height: 1;
  }

  .frente-card h3 {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--olive-deep);
    margin: 0 0 12px;
  }

  .frente-card p {
    margin: 0;
    color: var(--taupe);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  .gep-obs {
    color: var(--taupe);
    line-height: 1.7;
    font-size: 0.97rem;
    border-left: 3px solid var(--bronze);
    padding-left: 20px;
    margin: 0;
    max-width: 680px;
  }

  /* Prazo */
  .gep-prazo-inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 64px;
    align-items: start;
  }

  .gep-quote {
    background: var(--olive-deep);
    color: var(--sand);
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 0;
    padding: 36px 32px;
    border-radius: 4px;
    quotes: none;
  }

  /* Posts relacionados */
  .posts-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .posts-lista li {
    border-bottom: 1px solid var(--line);
    padding-bottom: 12px;
  }

  .posts-lista li:last-child {
    border-bottom: none;
  }

