---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import leadershipIcon from '../../assets/icons/leadership.svg?raw';
import strategyIcon from '../../assets/icons/strategy.svg?raw';
import assessmentIcon from '../../assets/icons/assessment.svg?raw';
import mentoringIcon from '../../assets/icons/mentoring.svg?raw';

const SITE_URL = 'https://eloysekonell.com.br';

const title = 'Serviços — Eloyse Konell | Liderança e Gestão Estratégica de Pessoas';
const description =
  'Desenvolvimento de líderes, gestão estratégica de pessoas, assessment executivo e mentoria para empresas e líderes no Sul do Brasil. Conheça as frentes de atuação.';
const canonical = `${SITE_URL}/servicos/`;

const breadcrumb = [
  { label: 'Início', href: '/' },
  { label: 'Serviços' },
];

const services = [
  {
    title: 'Assessment e Diagnóstico de Liderança',
    deck: 'Para empresas e líderes que precisam de dados objetivos antes de decisões críticas de promoção, sucessão ou contratação.',
    href: '/servicos/assessment/',
    iconHtml: assessmentIcon,
    bullets: [
      'Combinação de instrumentos validados — DISC e análise comportamental avançada',
      'Relatório executivo com recomendações estratégicas claras para o decisor',
      'Devolutiva individual e plano de desenvolvimento com prioridades definidas',
    ],
  },
  {
    title: 'Estratégias de Sucessão',
    deck: 'Para empresas que precisam estruturar quem vai sustentar o próximo ciclo — antes que a cadeira fique vazia.',
    href: '/servicos/estrategias-de-sucessao/',
    iconHtml: strategyIcon,
    bullets: [
      'Mapeamento de potencial e prontidão dos candidatos internos com critérios objetivos',
      'Plano de sucessão estruturado com cronograma e responsáveis definidos',
      'Acompanhamento do desenvolvimento dos sucessores até a transição',
    ],
  },
  {
    title: 'Mentoria de Transição de Carreira para Líderes',
    deck: 'Para líderes que estão mudando de papel, empresa ou nível — e precisam de um espaço estratégico para pensar com clareza.',
    href: '/servicos/mentoria-executiva/',
    iconHtml: mentoringIcon,
    bullets: [
      'Processo individual focado em decisão e direção em momentos de transição',
      'Análise comportamental integrada para mapear padrões que limitam ou impulsionam',
      'Acompanhamento de 3 a 6 meses com sessões estruturadas e metas claras',
    ],
  },
  {
    title: 'Desenvolvimento de Líderes',
    deck: 'Para empresas que precisam preparar gestores para o próximo nível de complexidade com método, não com treinamento genérico.',
    href: '/servicos/desenvolvimento-de-liderancas/',
    iconHtml: leadershipIcon,
    bullets: [
      'Programas sob medida para líderes em formação e gestores em transição de papel',
      'Abordagem baseada em neurociência, análise comportamental e contexto real do negócio',
      'Acompanhamento contínuo com indicadores claros de mudança de comportamento',
    ],
  },
];

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': canonical,
  name: 'Serviços',
  url: canonical,
  description,
  inLanguage: 'pt-BR',
  isPartOf: { '@id': `${SITE_URL}/#business` },
  hasPart: [
    { '@id': `${SITE_URL}/servicos/assessment/#service` },
    { '@id': `${SITE_URL}/servicos/estrategias-de-sucessao/#service` },
    { '@id': `${SITE_URL}/servicos/mentoria-executiva/#service` },
    { '@id': `${SITE_URL}/servicos/desenvolvimento-de-liderancas/#service` },
  ],
};
---

<PageLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumb={breadcrumb}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  </Fragment>

  <PageHero
    slot="hero"
    eyebrow="Serviços"
    title="Como posso ajudar"
    deck="Quatro frentes de atuação para empresas e líderes que querem método, não treinamento de prateleira."
  />

  <div class="wrap servicos-wrap">
    <p class="servicos-intro">
      Cada empresa atravessa momentos distintos: há quem precise formar líderes que ainda não existem
      no pipeline, quem precise estruturar processos de liderança que sustentem o crescimento, quem
      precise de um diagnóstico preciso antes de promover, suceder ou contratar, e quem precise de um
      espaço estratégico para pensar liderança com clareza. As quatro frentes abaixo foram desenhadas
      para esses momentos — não como pacotes genéricos, mas como respostas a perguntas reais.
    </p>

    <div class="servicos-grid">
      {services.map((s) => (
        <ServiceCard
          title={s.title}
          deck={s.deck}
          href={s.href}
          iconHtml={s.iconHtml}
          bullets={s.bullets}
        />
      ))}
    </div>

    <div class="servicos-cta">
      <p class="servicos-cta__text">Não sabe qual serviço encaixa? Vamos conversar.</p>
      <a href="/contato/" class="btn-ghost">Falar com Eloyse →</a>
    </div>
  </div>
</PageLayout>

<style>
  .servicos-wrap {
    padding-bottom: var(--space-11);
  }

  .servicos-intro {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--taupe);
    margin: 0 0 var(--space-10);
  }

  .servicos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-7);
    margin-bottom: var(--space-10);
  }

  .servicos-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-10) 0;
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .servicos-cta__text {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    color: var(--olive-deep);
    margin: 0;
  }

  @media (max-width: 900px) {
    .servicos-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .servicos-intro {
      margin-bottom: var(--space-8);
    }

    .servicos-grid {
      gap: var(--space-5);
    }

    .servicos-cta {
      padding: var(--space-9) 0;
    }
  }
</style>
