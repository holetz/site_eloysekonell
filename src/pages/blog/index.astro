---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const allPosts = (await getCollection('blog', ({ data }: any) => !data.draft))
  .sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = allPosts;

const categoryOrder = ['Estratégia', 'Liderança', 'Performance', 'Pessoas'];
const tagSet = new Set<string>();
allPosts.forEach((p: any) => p.data.tags.forEach((t: string) => tagSet.add(t)));
const categories = categoryOrder.filter((c) => tagSet.has(c));

function slugifyTag(tag: string) {
  return tag
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
}
---

<Layout
  title="Insights | Blog"
  description="Reflexões sobre liderança, estratégia e a arte de fazer pessoas performarem — por Eloyse Konell."
>
  <Nav />

  <main class="blog-main">
    <!-- HERO -->
    <section class="b-hero">
      <div class="wrap">
        <span class="b-eyebrow">Insights & Perspectivas</span>
        <h1>
          Reflexões sobre liderança, estratégia e a
          <em>arte de fazer pessoas performarem</em>.
        </h1>
        <p class="b-hero-lead">
          Conteúdo para líderes e profissionais que entendem que resultado e
          gente são, no fundo, o mesmo assunto.
        </p>
      </div>
    </section>

    {!featured ? (
      <section class="b-section">
        <div class="wrap">
          <p class="no-posts">Novos artigos em breve.</p>
        </div>
      </section>
    ) : (
      <>
        <!-- EM DESTAQUE -->
        <section class="b-section">
          <div class="wrap">
            <div class="section-title">
              <h2>Em destaque</h2>
              <div class="line"></div>
            </div>

            <a href={`/blog/${featured.slug}`} class="featured-card">
              <div
                class="featured-img"
                style={featured.data.coverImage
                  ? `background-image:url('${featured.data.coverImage}')`
                  : ''}
              ></div>
              <div class="featured-body">
                <div class="featured-head">
                  <span class="b-eyebrow">
                    {featured.data.tags[0]} · {featured.data.readingTime}
                  </span>
                  <h3>{featured.data.title}</h3>
                  <p>{featured.data.deck}</p>
                </div>
                <div class="featured-foot">
                  <time datetime={featured.data.pubDate.toISOString()}>
                    {formatDate(featured.data.pubDate)}
                  </time>
                  <span class="btn btn-bronze">Ler artigo</span>
                </div>
              </div>
            </a>
          </div>
        </section>

        {rest.length > 0 && (
          <!-- ARTIGOS RECENTES -->
          <section class="b-section b-section-articles" id="artigos">
            <div class="wrap">
              <div class="section-title">
                <h2>Artigos recentes</h2>
                <div class="line"></div>
              </div>

              <div class="categories">
                <button class="cat-pill active" data-filter="todos" type="button">
                  Todos
                </button>
                {categories.map((cat) => (
                  <button
                    class="cat-pill"
                    data-filter={slugifyTag(cat)}
                    type="button"
                  >
                    {cat}
                  </button>
                ))}
              </div>

              <div class="articles-grid">
                {rest.map((post: any) => (
                  <article
                    class="article"
                    data-cat={post.data.tags.map(slugifyTag).join(' ')}
                  >
                    <a href={`/blog/${post.slug}`} class="article-link">
                      <div
                        class="article-img"
                        style={post.data.coverImage
                          ? `background-image:url('${post.data.coverImage}')`
                          : ''}
                      ></div>
                      <div class="article-body">
                        <span class="b-eyebrow">
                          {post.data.tags[0]} · {post.data.readingTime}
                        </span>
                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>
                        <span class="read">Ler mais →</span>
                      </div>
                    </a>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}
      </>
    )}

    <!-- NEWSLETTER · O FATOR HUMANO -->
    <section class="nl-section" id="newsletter">
      <div class="nl-grid">
        <div class="nl-left">
          <span class="nl-eyebrow">Newsletter</span>
          <h2 class="nl-name">O <em>Fator<br />Humano</em></h2>
          <p class="nl-tagline">
            A leitura dos bastidores de quem decide sobre pessoas no topo da
            operação.
          </p>
          <div class="nl-meta">
            <div class="nl-meta-item">
              <span class="nl-meta-num">15</span>
              <span class="nl-meta-label">Em 15 dias</span>
            </div>
            <div class="nl-meta-item">
              <span class="nl-meta-num">10min</span>
              <span class="nl-meta-label">De leitura</span>
            </div>
          </div>
        </div>
        <div class="nl-right">
          <p class="nl-promise">
            Receba insights que normalmente
            <em>só meus clientes veem</em>.
          </p>
          <ul class="nl-list">
            <li>Análises sobre estratégia e liderança aplicadas ao dia a dia</li>
            <li>Bastidores de projetos reais, com decisões e desfechos</li>
            <li>Provocações que ajudam você a ler melhor o seu negócio</li>
          </ul>
          <a
            href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7449821423914844162"
            target="_blank"
            rel="noopener"
            class="btn-linkedin"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.22 0z"/>
            </svg>
            Assinar no LinkedIn
          </a>
          <p class="nl-disclaimer">
            Você recebe direto no seu feed. Sem spam, sem cadastro extra.
          </p>
        </div>
      </div>
    </section>

    <!-- SOBRE A AUTORA -->
    <section class="b-section b-author-section">
      <div class="wrap">
        <div class="author">
          <div
            class="author-photo"
            style="background-image:url('/images/photos/eloyse-author-blog.jpg')"
            aria-label="Eloyse Konell"
          ></div>
          <div class="author-content">
            <span class="b-eyebrow">Sobre a autora</span>
            <h2>Eloyse <em>Konell</em></h2>
            <p class="author-tag">
              Psicóloga de formação, estrategista de liderança na prática.
            </p>
            <p>
              Há mais de uma década, ajudo empresas a transformar liderança em
              resultado. Trabalho onde o comportamento humano encontra a
              estratégia de negócio, formando líderes do zero em contextos
              complexos, conduzindo <em>assessments</em> que revelam o que
              nenhuma ferramenta sozinha mostra e desenhando jornadas que
              sustentam crescimento real.
            </p>
            <p>
              Não vendo método pronto: entrego clareza, decisão e gente
              preparada para o que vem.
            </p>
            <p>
              Se sua empresa está crescendo ou se transformando mais rápido do
              que sua liderança consegue acompanhar, esse é exatamente o tipo
              de desafio que eu resolvo.
            </p>
            <a href="/" class="btn">Conhecer meu trabalho</a>
          </div>
        </div>
      </div>
    </section>

    <!-- PARCEIROS -->
    <section class="partners">
      <div class="wrap">
        <div class="partners-header">
          <span class="b-eyebrow">Conteúdo de parceiros</span>
          <h2>Vozes que <em>respeito</em></h2>
          <p>
            Espaço dedicado a artigos de parceiros estratégicos e referências
            do mercado que complementam a conversa.
          </p>
        </div>
        <div class="partners-grid">
          <div class="partner-card">
            <div
              class="partner-logo"
              style="background-image:url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=600&q=85')"
              aria-hidden="true"
            ></div>
            <div>
              <span class="b-eyebrow">Parceiro convidado</span>
              <h3>Em breve: o primeiro artigo convidado</h3>
              <p>
                Espaço reservado para uma voz do mercado que complementa a
                conversa.
              </p>
            </div>
          </div>
          <div class="partner-card">
            <div
              class="partner-logo"
              style="background-image:url('https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=600&q=85')"
              aria-hidden="true"
            ></div>
            <div>
              <span class="b-eyebrow">Seja parceiro</span>
              <h3>Quer publicar aqui?</h3>
              <p>
                Aceito contribuições selecionadas de profissionais com visão
                alinhada.
                <a
                  href="https://wa.me/5547991443844"
                  target="_blank"
                  rel="noopener"
                >Fale comigo</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.cat-pill').forEach((pill) => {
    pill.addEventListener('click', () => {
      document
        .querySelectorAll('.cat-pill')
        .forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');

      const filter = pill.dataset.filter;
      document.querySelectorAll<HTMLElement>('.articles-grid .article').forEach((article) => {
        const cats = (article.dataset.cat || '').split(' ');
        const match = filter === 'todos' || cats.includes(filter || '');
        article.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .blog-main { padding-top: 0; }

  /* Override site default eyebrow inside blog (no leading line) */
  .blog-main .b-eyebrow {
    font-family: var(--sans);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bronze);
    font-weight: 600;
    display: inline-block;
  }

  /* Section spacing */
  .blog-main .b-section { padding: 90px 0; }
  .blog-main .b-section-articles { padding-top: 0; }

  /* HERO */
  .b-hero {
    background: var(--sand-warm);
    padding: 200px 0 110px;
    text-align: center;
    border-bottom: 1px solid var(--line);
  }
  .b-hero .b-eyebrow { margin-bottom: 24px; }
  .b-hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    line-height: 1.1;
    max-width: 880px;
    margin: 0 auto 28px;
    font-weight: 400;
  }
  .b-hero h1 em { color: var(--bronze); font-weight: 400; font-style: italic; }
  .b-hero-lead {
    color: var(--taupe);
    max-width: 580px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.65;
  }

  /* Section title with horizontal line */
  .section-title {
    display: flex;
    align-items: end;
    gap: 24px;
    margin-bottom: 56px;
  }
  .section-title h2 {
    font-size: clamp(1.9rem, 3.4vw, 2.6rem);
    margin: 0;
  }
  .section-title .line {
    flex: 1;
    height: 1px;
    background: var(--line);
    margin-bottom: 14px;
  }

  /* FEATURED */
  .featured-card {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    background: var(--sand-warm);
    border: 1px solid var(--line);
    text-decoration: none;
    transition: border-color 0.3s, box-shadow 0.3s;
    align-items: stretch;
  }
  .featured-card:hover {
    border-color: var(--bronze);
    box-shadow: 0 16px 40px rgba(46, 45, 34, 0.08);
  }
  .featured-img {
    background: var(--olive-deep);
    background-size: cover;
    background-position: center;
    min-height: 420px;
  }
  .featured-body {
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 36px;
  }
  .featured-head .b-eyebrow { display: block; margin-bottom: 18px; }
  .featured-head h3 {
    font-size: clamp(1.55rem, 2.4vw, 2.05rem);
    line-height: 1.18;
    margin: 0 0 18px;
    color: var(--olive-deep);
  }
  .featured-head p {
    color: var(--taupe);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
  }
  .featured-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }
  .featured-foot time {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--taupe-soft);
    font-weight: 500;
  }
  .btn-bronze {
    background: var(--bronze);
    border-color: var(--bronze);
    color: var(--olive-deep);
  }
  .btn-bronze:hover {
    background: transparent;
    color: var(--bronze);
    border-color: var(--bronze);
  }

  /* CATEGORIES FILTER */
  .categories {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }
  .cat-pill {
    padding: 11px 24px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--olive);
    font-family: var(--sans);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
  }
  .cat-pill:hover,
  .cat-pill.active {
    background: var(--olive-deep);
    color: var(--sand);
    border-color: var(--olive-deep);
  }

  /* ARTICLES GRID */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px;
  }
  .article {
    background: var(--sand-warm);
    border: 1px solid var(--line);
    transition: transform 0.35s, box-shadow 0.35s, border-color 0.3s;
  }
  .article:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(46, 45, 34, 0.08);
    border-color: var(--bronze);
  }
  .article-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .article-img {
    height: 240px;
    background: var(--olive);
    background-size: cover;
    background-position: center;
  }
  .article-body { padding: 32px 30px; }
  .article-body .b-eyebrow { margin-bottom: 14px; display: block; }
  .article h3 {
    font-size: 1.4rem;
    line-height: 1.22;
    margin: 0 0 14px;
    color: var(--olive-deep);
    transition: color 0.3s;
  }
  .article-link:hover h3 { color: var(--bronze); }
  .article p {
    color: var(--taupe);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 22px;
  }
  .read {
    font-family: var(--sans);
    color: var(--olive-deep);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    border-bottom: 1px solid var(--bronze);
    padding-bottom: 3px;
  }

  .no-posts {
    font-size: 1.1rem;
    color: var(--taupe-soft);
    padding: 40px 0;
  }

  /* NEWSLETTER · O FATOR HUMANO */
  .nl-section {
    background: var(--olive-deep);
    color: var(--sand);
    margin: 90px 0;
    position: relative;
    overflow: hidden;
  }
  .nl-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    min-height: 560px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .nl-left {
    padding: 80px 70px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid rgba(194, 166, 121, 0.18);
    position: relative;
  }
  .nl-left::before {
    content: '';
    position: absolute;
    top: 80px;
    left: 70px;
    width: 50px;
    height: 1px;
    background: var(--bronze);
  }
  .nl-eyebrow {
    font-family: var(--sans);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--bronze);
    font-weight: 600;
    margin-top: 24px;
    margin-bottom: 28px;
    display: block;
  }
  .nl-name {
    font-family: var(--serif);
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 0.95;
    color: var(--sand);
    font-weight: 500;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .nl-name em { color: var(--bronze-soft); font-weight: 400; font-style: italic; }
  .nl-tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--sand-deep);
    margin: 12px 0 36px;
    line-height: 1.4;
    max-width: 440px;
  }
  .nl-meta {
    display: flex;
    gap: 36px;
    padding-top: 28px;
    border-top: 1px solid rgba(194, 166, 121, 0.2);
  }
  .nl-meta-item { display: flex; flex-direction: column; gap: 4px; }
  .nl-meta-num {
    font-family: var(--serif);
    font-size: 2rem;
    color: var(--bronze-soft);
    font-weight: 500;
    line-height: 1;
  }
  .nl-meta-label {
    font-family: var(--sans);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sand-deep);
    opacity: 0.75;
  }
  .nl-right {
    padding: 80px 70px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--olive);
  }
  .nl-promise {
    font-family: var(--serif);
    font-size: 1.6rem;
    line-height: 1.35;
    color: var(--sand);
    margin: 0 0 32px;
    font-weight: 400;
  }
  .nl-promise em { color: var(--bronze-soft); font-style: italic; }
  .nl-list {
    list-style: none;
    margin: 0 0 40px;
    padding: 0;
  }
  .nl-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(194, 166, 121, 0.15);
    font-size: 0.92rem;
    color: var(--sand-deep);
    font-weight: 300;
    line-height: 1.5;
  }
  .nl-list li:last-child { border-bottom: none; }
  .nl-list li::before {
    content: '—';
    color: var(--bronze);
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .btn-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 20px 44px;
    background: var(--bronze);
    color: var(--olive-deep);
    font-family: var(--sans);
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    border: 1px solid var(--bronze);
    transition: all 0.3s;
    text-decoration: none;
    align-self: flex-start;
  }
  .btn-linkedin:hover {
    background: transparent;
    color: var(--bronze);
    border-color: var(--bronze);
  }
  .nl-disclaimer {
    font-size: 0.82rem;
    color: var(--sand-deep);
    opacity: 0.7;
    margin-top: 18px;
  }

  /* AUTHOR */
  .b-author-section { padding-top: 0; }
  .author {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 60px;
    align-items: center;
    background: var(--sand-warm);
    padding: 70px;
    border: 1px solid var(--line);
  }
  .author-photo {
    aspect-ratio: 4 / 5;
    background-color: var(--olive);
    background-size: cover;
    background-position: center;
  }
  .author-content .b-eyebrow { margin-bottom: 14px; display: block; }
  .author-content h2 {
    font-size: clamp(2rem, 3.6vw, 2.8rem);
    margin: 0 0 22px;
  }
  .author-content h2 em { color: var(--bronze); font-weight: 400; font-style: italic; }
  .author-tag {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--olive-deep);
    margin-bottom: 28px;
    line-height: 1.45;
  }
  .author-content p {
    color: var(--taupe);
    margin-bottom: 18px;
    font-size: 1rem;
    line-height: 1.65;
  }
  .author-content em { color: var(--bronze); font-style: italic; }
  .author-content .btn { margin-top: 18px; }

  /* PARTNERS */
  .partners {
    background: var(--sand-warm);
    padding: 90px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .partners-header { text-align: center; margin-bottom: 60px; }
  .partners-header .b-eyebrow { display: inline-block; margin-bottom: 14px; }
  .partners-header h2 {
    font-size: clamp(1.9rem, 3.4vw, 2.6rem);
    margin: 0;
  }
  .partners-header h2 em { color: var(--bronze); font-weight: 400; font-style: italic; }
  .partners-header p {
    color: var(--taupe);
    max-width: 580px;
    margin: 16px auto 0;
  }
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    max-width: 1040px;
    margin: 0 auto;
  }
  .partner-card {
    display: grid;
