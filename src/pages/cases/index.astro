---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CaseCard from '../../components/CaseCard.astro';

const SITE_URL = 'https://eloysekonell.com.br';

const allCases = await getCollection('cases', ({ data }) => !data.draft);
allCases.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const breadcrumb = [
  { label: 'Início', href: '/' },
  { label: 'Cases' },
];

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cases — Eloyse Konell',
  description: 'Resultados de aplicação do método em diferentes contextos organizacionais.',
  url: `${SITE_URL}/cases/`,
  author: { '@id': `${SITE_URL}/#eloyse` },
  publisher: { '@id': `${SITE_URL}/#business` },
  ...(allCases.length > 0 && {
    hasPart: allCases.map((c) => ({
      '@type': 'Article',
      headline: c.data.title,
      url: `${SITE_URL}/cases/${c.slug}/`,
    })),
  }),
};
---

<PageLayout
  title="Cases — Resultados em contexto real"
  description="Estudos de caso da consultoria Eloyse Konell: como liderança e gestão estratégica de pessoas geraram resultados mensuráveis em diferentes organizações."
  canonical={`${SITE_URL}/cases/`}
  breadcrumb={breadcrumb}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  </Fragment>

  <div slot="hero">
    <PageHero
      eyebrow="Cases"
      title="Resultados em contexto real"
      deck="Resultados de aplicação do método em diferentes contextos organizacionais."
    />
  </div>

  {allCases.length === 0 ? (
    <div class="cases-placeholder">
      <p>Cases em preparação. Em breve.</p>
    </div>
  ) : (
    <section class="cases-grid-section">
      <div class="cases-grid">
        {allCases.map((entry) => (
          <CaseCard entry={entry} />
        ))}
      </div>
    </section>
  )}
</PageLayout>

<style>
  .cases-placeholder {
    padding: 80px 0 60px;
    text-align: center;
    color: var(--taupe);
    font-style: italic;
    font-family: var(--serif);
    font-size: 1.2rem;
  }

  .cases-grid-section {
    padding: 60px 0 80px;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 1100px) {
    .cases-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 680px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
