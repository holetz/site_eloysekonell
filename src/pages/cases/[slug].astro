---
import { getCollection } from 'astro:content';
import CaseLayout from '../../layouts/CaseLayout.astro';

export async function getStaticPaths() {
  const cases = await getCollection('cases', ({ data }) => !data.draft);
  return cases.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title,
  client,
  clientUrl,
  sector,
  problem,
  approach,
  result,
  metric,
  pubDate,
  updatedDate,
  coverImage,
} = entry.data;

const description = `Case de consultoria com ${client}: ${problem}`;
---

<CaseLayout
  title={title}
  description={description}
  client={client}
  clientUrl={clientUrl}
  sector={sector}
  problem={problem}
  approach={approach}
  result={result}
  metric={metric}
  pubDate={pubDate}
  updatedDate={updatedDate}
  ogImage={coverImage}
  slug={entry.slug}
>
  <Content />
</CaseLayout>
