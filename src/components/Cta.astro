<!-- CTA -->
<section class="cta" id="contato">
  <div class="wrap">
    <span class="eyebrow reveal">Vamos Conversar</span>
    <h2 class="reveal delay-1">
      O próximo ciclo da sua organização <em>começa agora.</em>
    </h2>
    <a
      href="https://api.whatsapp.com/send/?phone=5547991443844"
      class="btn reveal delay-2"
      target="_blank"
      rel="noopener"
    >
      Agendar Diagnóstico
    </a>
    <p class="cta-link reveal delay-3">
      <a href="/contato/">Ver formas de contato →</a>
    </p>
  </div>
</section>

<style>
  .cta-link {
    margin-top: 1rem;
    font-size: 0.95rem;
  }
  .cta-link a {
    color: var(--bronze-soft);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    transition: color 0.2s;
  }
  .cta-link a:hover {
    color: var(--sand);
  }
</style>
