<!-- HERO -->
<section class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <span class="eyebrow reveal">Consultoria Estratégica</span>
        <h1 class="reveal delay-1">
          Liderança de alta performance <em>é tema de estratégia</em>
        </h1>
        <p class="lead reveal delay-2">
          Há mais de 10 anos desenvolvendo líderes, estruturando áreas de pessoas e desenhando
