---
import { Image } from 'astro:assets';
import heroImg from '../assets/photos/eloyse-hero.jpg';
---
<!-- HERO -->
<section class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <span class="eyebrow reveal">Consultoria Estratégica</span>
        <h1 class="reveal delay-1">
          Liderança de alta performance <em>é tema de estratégia</em>
        </h1>
        <p class="lead reveal delay-2">
          Psicóloga & Consultora Estratégica de Lideranças. Há mais de 10 anos desenvolvendo líderes e ajudando organizações a identificar quem vai sustentar o próximo ciclo de crescimento.
        </p>
        <div class="hero-cta reveal delay-3">
          <a href="/#contato" class="btn">DIAGNÓSTICO DE LIDERANÇA</a>
          <a href="/#servicos" class="btn-ghost">Ver Soluções</a>
        </div>
      </div>
      <div class="hero-visual reveal delay-2">
        <div class="photo">
          <Image
            src={heroImg}
            alt="Eloyse Konell — Consultora em Liderança e Gestão Estratégica de Pessoas"
            loading="eager"
            fetchpriority="high"
            widths={[460, 920]}
            sizes="(max-width: 900px) 360px, 460px"
          />
        </div>
        <div class="hero-mark">
          <strong>+10 anos</strong>
          transformando lacunas de liderança em vantagem competitiva para empresas em transformação.
        </div>
      </div>
    </div>
  </div>
</section>
