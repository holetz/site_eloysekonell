---
import { Image } from 'astro:assets';
import logoDatarunk from '../assets/logos/logo_datarunk.png';
import logoDgsis from '../assets/logos/logo_dgsis.png';
import logoGrupoTop from '../assets/logos/logo_grupo_top.png';
import logoPossibilitar from '../assets/logos/logo_possibilitar.png';
import logoNuvme from '../assets/logos/logo_nuvme.png';
import logoStraas from '../assets/logos/logo_straas.png';
import logoColablife from '../assets/logos/logo_colablife.png';
import logoTechlinker from '../assets/logos/logo_techlinker.webp';
import logoMtech from '../assets/logos/logo_mtech.png';
import logoGuion from '../assets/logos/logo_guion.png';
import logoOliveiraEAntunes from '../assets/logos/logo_oliveira_e_antunes.png';

const clients = [
  { src: logoDatarunk,    alt: 'Datarunk' },
  { src: logoDgsis,       alt: 'DGSis' },
  { src: logoGrupoTop,    alt: 'Grupo Top' },
  { src: logoPossibilitar,alt: 'Possibilitar' },
  { src: logoNuvme,       alt: 'Nuvme' },
  { src: logoStraas,      alt: 'Straas' },
  { src: logoColablife,   alt: 'Colablife' },
  { src: logoTechlinker,  alt: 'Techlinker' },
  { src: logoMtech,       alt: 'Mtech' },
  { src: logoGuion,       alt: 'Guion' },
  { src: logoOliveiraEAntunes, alt: 'Oliveira e Antunes' },
];
---
<!-- CLIENTES -->
<section class="clients">
  <div class="wrap">
    <div class="clients-head reveal">
      <span class="eyebrow">Alianças que Transformam</span>
    </div>
    <div class="clients-grid reveal delay-1">
      {clients.map(({ src, alt }) => (
        <Image
          class="client-logo"
          src={src}
          alt={alt}
          width={240}
          height={80}
          loading="lazy"
          formats={['avif', 'webp']}
        />
      ))}
    </div>
  </div>
</section>
