---
export interface Props {
  faqs: Array<{ q: string; a: string }>;
  title?: string;
}

const { faqs, title = 'Perguntas frequentes' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};
---

<div class="faq-block" role="region" aria-labelledby="faq-title">
  <h2 class="faq-title" id="faq-title">{title}</h2>
  <div class="faq-list">
    {faqs.map(({ q, a }, i) => (
      <div class="faq-item">
        <button
          class="faq-question"
          aria-expanded="false"
          aria-controls={`faq-resp-${i}`}
          id={`faq-btn-${i}`}
          type="button"
        >
          {q}
          <span class="faq-icon" aria-hidden="true">+</span>
        </button>
        <div
          class="faq-answer"
          id={`faq-resp-${i}`}
          role="region"
          aria-labelledby={`faq-btn-${i}`}
          hidden
        >
          <p>{a}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const panelId = btn.getAttribute('aria-controls');
      const panel = panelId ? document.getElementById(panelId) : null;
      const icon = btn.querySelector('.faq-icon');

      btn.setAttribute('aria-expanded', String(!isExpanded));
      if (panel) {
        if (isExpanded) {
          panel.setAttribute('hidden', '');
        } else {
          panel.removeAttribute('hidden');
        }
      }
      if (icon) {
        (icon as HTMLElement).style.transform = isExpanded ? '' : 'rotate(45deg)';
      }
      btn.closest('.faq-item')?.classList.toggle('open', !isExpanded);
    });
  });
</script>

<style>
  .faq-block {
    margin: 3rem 0;
  }

  .faq-title {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--olive-deep);
    margin-bottom: 1.5rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    border: var(--border-line);
    border-radius: 6px;
    background: var(--sand);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item.open {
    border-color: var(--bronze);
  }

  .faq-question {
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    font-family: var(--font-sans, 'Manrope', sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--olive-deep);
    cursor: pointer;
    user-select: none;
  }

  .faq-icon {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--bronze);
    flex-shrink: 0;
    transition: transform 0.2s;
    display: inline-block;
  }

  .faq-answer {
    padding: 0 1.25rem 1rem;
    font-family: var(--font-sans, 'Manrope', sans-serif);
    font-size: 0.9375rem;
    color: var(--taupe);
    line-height: 1.7;
  }

  .faq-answer p {
    margin: 0;
  }
</style>
