---
export interface Props {
  title: string;
  deck: string;
  href?: string;
  iconHtml?: string;
  bullets?: string[];
}

const { title, deck, href, iconHtml, bullets } = Astro.props;
---

<article class="service-card">
  {iconHtml && <span class="service-card__icon" aria-hidden="true" set:html={iconHtml} />}
  <h2 class="service-card__title">{title}</h2>
  <p class="service-card__deck">{deck}</p>
  {bullets && bullets.length > 0 && (
    <ul class="service-card__bullets">
      {bullets.map((item) => <li>{item}</li>)}
    </ul>
  )}
  {href && <a href={href} class="service-card__link">Saiba mais →</a>}
</article>

<style>
  .service-card {
    background: var(--sand-warm);
    border: var(--border-line);
    padding: 44px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    border-color: var(--bronze);
    box-shadow: var(--shadow-md);
    transform: translateY(calc(var(--space-1) * -1));
  }

  .service-card__icon {
    display: inline-flex;
    width: var(--space-8, 40px);
    height: var(--space-8, 40px);
    color: var(--bronze);
    margin-bottom: var(--space-5, 20px);
  }

  .service-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-card__title {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--olive-deep);
    margin: 0;
  }

  .service-card__deck {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--taupe);
    margin: 0;
    flex: 1;
  }

  .service-card__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .service-card__bullets li {
    font-size: 0.92rem;
    color: var(--taupe);
    line-height: 1.5;
    padding-left: 20px;
    position: relative;
  }

  .service-card__bullets li::before {
    content: '—';
    color: var(--bronze);
    font-weight: 600;
    position: absolute;
    left: 0;
  }

  .service-card__link {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--olive-deep);
    border-bottom: 1px solid var(--bronze);
    padding-bottom: 3px;
    align-self: flex-start;
    transition: color 0.3s;
  }

  .service-card:hover .service-card__link {
    color: var(--bronze);
  }
</style>
